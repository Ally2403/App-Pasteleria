# VARIABLES DE ENTORNO — App Pastelería Mami 🎂
# Copia este archivo como ".env" (o ".env.local" para desarrollo local)
# y reemplaza los valores con las credenciales de tu proyecto de Supabase.

# URL de API REST de Supabase (Project Settings -> API -> Project URL)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública anónima de Supabase (Project Settings -> API -> Anon Key)
VITE_SUPABASE_ANON_KEY=tu-clave-publica-anonima-aqui
